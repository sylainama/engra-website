---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="max-w-3xl mx-auto space-y-3">
  {items.map((item) => (
    <details class="group rounded-xl border overflow-hidden" style="background: var(--color-surface); border-color: var(--color-border);">
      <summary class="flex items-center justify-between px-6 py-4 text-sm font-medium" style="color: var(--color-text);">
        <span>{item.question}</span>
        <svg class="faq-chevron w-5 h-5 flex-shrink-0 transition-transform duration-200" style="color: var(--color-muted);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </summary>
      <div class="px-6 pb-4 text-sm leading-relaxed" style="color: var(--color-muted);">{item.answer}</div>
    </details>
  ))}
</div>
