---
import Page from "../../layouts/Page.astro";
import DownloadCard from "../../components/DownloadCard.astro";

const locale = "en";
const releaseBase = "https://engra-download-proxy.syl-ainama.workers.dev/latest";
---

<Page title="Download Engra" description="Download Engra for free on macOS, Linux or Windows." locale={locale}>
  <section class="pt-24 pb-8 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl lg:text-5xl mb-4" style="font-family: var(--font-serif); color: var(--color-text);">
        Download Engra
      </h1>
      <p class="text-lg" style="color: var(--color-muted);">
        Choose your platform. Free to download.
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-6" id="download-cards">
        <DownloadCard
          locale={locale}
          platform="macOS"
          icon=""
          filename="Engra-macOS.dmg"
          requirements={["macOS 13 (Ventura) or later", "Apple Silicon + Intel (Universal)", "Signed and notarized by Apple"]}
          downloadUrl={`${releaseBase}/macos`}
        />
        <DownloadCard
          locale={locale}
          platform="Linux"
          icon="🐧"
          filename="Engra-Linux-x64.tar.gz"
          requirements={["Ubuntu 22.04+, Fedora 38+, Arch", "x86_64", "GTK3 required"]}
          downloadUrl={`${releaseBase}/linux`}
        />
        <DownloadCard
          locale={locale}
          platform="Windows"
          icon="🪟"
          filename="Engra-Windows-x64.zip"
          requirements={["Windows 10/11 64-bit", "Extract and run, no installer", "x86_64"]}
          downloadUrl={`${releaseBase}/windows`}
        />
      </div>
    </div>
  </section>

  <!-- Prerequisites -->
  <section class="py-16" style="background: var(--color-surface);">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl font-semibold mb-8 text-center" style="color: var(--color-text);">Prerequisites</h2>
      <div class="space-y-6">
        <div class="p-5 rounded-xl border" style="border-color: var(--color-border);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-text);">Transcription</h3>
          <p class="text-sm" style="color: var(--color-muted);">
            The transcription engine is downloaded and installed automatically on first launch. Nothing to do.
          </p>
        </div>
        <div class="p-5 rounded-xl border" style="border-color: var(--color-border);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-text);">AI Summaries — Optional</h3>
          <p class="text-sm" style="color: var(--color-muted);">
            AI models for automatic summaries can be downloaded in one click from the app settings. No technical configuration required.
          </p>
        </div>
        <div class="p-5 rounded-xl border" style="border-color: var(--color-border);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-text);">Recommended specs</h3>
          <ul class="text-sm space-y-1.5" style="color: var(--color-muted);">
            <li>• 8 GB RAM minimum (16 GB recommended for advanced models)</li>
            <li>• 5 GB minimum disk space</li>
            <li>• macOS: Microphone + Screen Recording permission (for system audio)</li>
          </ul>
        </div>
      </div>
      <div class="mt-8 text-center">
        <a href="/en/guide/installation" class="text-sm font-medium underline underline-offset-2" style="color: var(--color-accent);">
          Full installation guide →
        </a>
      </div>
    </div>
  </section>
</Page>

<script is:inline>
  const ua = navigator.userAgent.toLowerCase();
  let detected = "linux";
  if (ua.includes("mac")) detected = "macos";
  else if (ua.includes("win")) detected = "windows";

  document.querySelectorAll("[data-platform]").forEach((card) => {
    if (card.dataset.platform === detected) {
      card.classList.add("ring-2");
      card.style.setProperty("ring-color", "var(--color-accent)");
      card.parentElement?.prepend(card);
    }
  });
</script>
